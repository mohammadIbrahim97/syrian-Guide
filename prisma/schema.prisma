// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// User & Auth Models
// ==========================================

model User {
  id               String   @id
  name             String?
  email            String   @unique
  image            String?
  role             Role     @default(TOURIST)
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  guideProfile Guide?
  bookings     Booking[]
}

enum Role {
  TOURIST
  GUIDE
  ADMIN
}

// ==========================================
// Guide Profile
// ==========================================

model Guide {
  id              String    @id @default(cuid())
  userId          String    @unique
  bio             String    @db.Text
  city            String
  phone           String? // WhatsApp/phone — revealed to the tourist only after a paid booking, never publicly
  languages       String[] // e.g., ["English", "Arabic", "German"]
  guideType       GuideType @default(STUDENT)
  university      String? // students: which university they attend
  hourlyRate      Float? // students: price per hour
  packagePrice    Float? // professionals: fixed package price per person
  packageDuration Int? // professionals: package length in minutes
  maxGroupSize    Int       @default(1)
  rating          Float     @default(0.0)
  reviewCount     Int       @default(0)
  isVerified      Boolean   @default(false)

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings          Booking[]
  availabilitySlots AvailabilitySlot[]
  photos            GuidePhoto[]
}

enum GuideType {
  STUDENT
  PROFESSIONAL
}

// ==========================================
// Guide Tour Gallery
// ==========================================

model GuidePhoto {
  id        String   @id @default(cuid())
  guideId   String
  url       String
  createdAt DateTime @default(now())

  guide Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
}

// ==========================================
// Availability Slots
// ==========================================

model AvailabilitySlot {
  id        String   @id @default(cuid())
  guideId   String
  date      DateTime @db.Date
  startTime String // e.g. "09:00"
  endTime   String // e.g. "13:00"
  isBooked  Boolean  @default(false)
  createdAt DateTime @default(now())

  guide   Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  booking Booking?

  @@unique([guideId, date, startTime])
}

// ==========================================
// Bookings
// ==========================================

model Booking {
  id              String        @id @default(cuid())
  guideId         String
  slotId          String?       @unique // the availability slot this booking consumes
  userId          String
  date            DateTime
  durationHours   Int? // student (hourly) bookings
  participants    Int           @default(1)
  status          BookingStatus @default(PENDING)
  totalPrice      Float
  stripeSessionId String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  guide Guide             @relation(fields: [guideId], references: [id], onDelete: Restrict)
  slot  AvailabilitySlot? @relation(fields: [slotId], references: [id], onDelete: Restrict)
  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

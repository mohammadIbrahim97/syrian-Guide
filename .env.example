# Copy to .env and fill in real values. All five variables are required in production.

# Postgres connection string.
# NOTE: must be set BEFORE `npm install` — the postinstall `prisma generate`
# loads prisma.config.ts, which throws if DATABASE_URL is missing.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/syriaguide?schema=public"

# Secret for NextAuth v5 session/JWT encryption. Generate with: openssl rand -base64 32
# (the legacy name NEXTAUTH_SECRET is also honored as a fallback)
AUTH_SECRET="change-me-32-chars-minimum"

# Public base URL of the app. Used to build the Stripe Checkout
# success/cancel redirect URLs.
NEXTAUTH_URL="http://localhost:3000"

# Stripe API keys (use test-mode keys locally): https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."

# Signing secret of the Stripe webhook endpoint pointed at /api/webhook.
# REQUIRED: the webhook refuses to process events without it (unsigned
# events could otherwise confirm unpaid bookings).
# Local dev: `stripe listen --forward-to localhost:3000/api/webhook` prints one.
STRIPE_WEBHOOK_SECRET="whsec_..."
